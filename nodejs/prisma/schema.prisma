// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id           Int      @id @default(autoincrement())
  uid          String   @unique
  name         String
  email        String   @unique
  profile_pic  String?
  xp           Int      @default(0)
  level        Int      @default(1)
  streak_count Int      @default(0)
  joined_at    DateTime @default(now())

  playlists    Playlist[]
  videos       Video[]
  quizzes      Quiz[]
  certificates Certificate[]
  activities   UserActivityLog[]
  notes        VideoNote[]
  comments     VideoComment[]
  
  supportTickets SupportTicket[]
  adminResponses SupportResponse[] @relation("AdminResponses")

  sentMessages     InboxMessage[] @relation("SentMessages")
  receivedMessages InboxMessage[] @relation("ReceivedMessages")
  readStatuses     MessageReadStatus[]
}

model InboxMessage {
  id          Int          @id @default(autoincrement())
  sender      UserProfile? @relation("SentMessages", fields: [senderId], references: [id], onDelete: SetNull)
  senderId    Int?         // Admin who sent it
  receiver    UserProfile? @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId  Int?         // Specific user ID or null for broadcast
  isBroadcast Boolean      @default(false)
  subject     String
  message     String       @db.Text
  isRead      Boolean      @default(false) // For direct messages
  created_at  DateTime     @default(now())

  readStatuses MessageReadStatus[]
}

model MessageReadStatus {
  id        Int          @id @default(autoincrement())
  user      UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  message   InboxMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId Int
  read_at   DateTime     @default(now())

  @@unique([userId, messageId])
}

model Playlist {
  id          Int      @id @default(autoincrement())
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  pid         String
  name        String
  url         String
  thumbnail   String?
  imported_at  DateTime @default(now())
  duration_goal Int?

  videos       Video[]
  quizzes      Quiz[]
  certificates Certificate[]

  @@unique([userId, pid])
}

model Video {
  id             Int      @id @default(autoincrement())
  user           UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int
  vid            String
  name           String
  url            String
  description    String?  @db.Text
  playlist       Playlist? @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playlistId     Int?
  imported_at    DateTime
  watch_progress Float    @default(0.0)
  is_completed   Boolean  @default(false)
  position       Int      @default(0)
  duration_seconds Int    @default(0)
  updated_at     DateTime @default(now()) @updatedAt

  quizzes      Quiz[]
  certificates Certificate[]

  @@unique([userId, vid])
}

model Quiz {
  id           Int      @id @default(autoincrement())
  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  video        Video?   @relation(fields: [videoId], references: [id], onDelete: SetNull)
  videoId      Int?
  playlist     Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  playlistId   Int?
  questions    String   @db.Text
  user_answers String?  @db.Text
  score        Float?
  passed       Boolean?
  is_combined  Boolean  @default(false)
  time_limit   Int      @default(15) // In minutes
  attempted_at DateTime @default(now())
}

model Certificate {
  id             Int      @id @default(autoincrement())
  user           UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int
  video          Video?   @relation(fields: [videoId], references: [id], onDelete: SetNull)
  videoId        Int?
  playlist       Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  playlistId     Int?
  certificate_id String   @unique @default(uuid())
  issued_at      DateTime @default(now())
  download_url   String?
}

model UserActivityLog {
  id            Int      @id @default(autoincrement())
  user          UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        Int
  activity_type String
  timestamp     DateTime @default(now())
}

model VideoNote {
  id         Int      @id @default(autoincrement())
  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  vid        String
  content    String   @db.Text
  updated_at DateTime @updatedAt

  files      VideoNoteFile[]

  @@unique([userId, vid])
}

model VideoNoteFile {
  id            Int       @id @default(autoincrement())
  note          VideoNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  noteId        Int
  file          String    // Path to file
  original_name String?   // Original filename from user
  uploaded_at   DateTime  @default(now())
}

model VideoComment {
  id         Int      @id @default(autoincrement())
  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  vid        String
  content    String   @db.Text
  parent     VideoComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId   Int?
  replies    VideoComment[] @relation("CommentReplies")
  created_at DateTime @default(now())
}




model VideoIntuition {
  id              Int      @id @default(autoincrement())
  vid             String   @unique
  content         String   @db.Text
  model_name      String?  // The name of the AI model that generated this
  transcript_used Boolean  @default(false) // True if generated from actual video transcript
  generated_at    DateTime @default(now())
}

model VideoQuizData {
  id           Int      @id @default(autoincrement())
  vid          String   @unique
  questions    String   @db.Text // Stored as JSON string
  generated_at DateTime @default(now())
}

model SupportTicket {
  id          Int      @id @default(autoincrement())
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  subject     String
  message     String   @db.Text
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  responses   SupportResponse[]
}

model SupportResponse {
  id          Int      @id @default(autoincrement())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    Int
  admin       UserProfile? @relation("AdminResponses", fields: [adminId], references: [id], onDelete: SetNull)
  adminId     Int?
  message     String   @db.Text
  created_at  DateTime @default(now())
}

