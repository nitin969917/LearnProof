# --- API KEYS (DO NOT PUSH REAL KEYS TO GITHUB) ---
# Copy these from your local .env to the server manually
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GROQ_API_KEY="YOUR_GROQ_KEY"
OPENROUTER_API_KEY="YOUR_OPENROUTER_KEY"
CEREBRAS_API_KEY="YOUR_CEREBRAS_KEY"
PINECONE_API_KEY="YOUR_PINECONE_KEY"
PINECONE_INDEX="YOUR_PINECONE_INDEX"

# --- GOOGLE CLOUD VERTEX AI CREDITS CONFIG ---
# (Define these to route Gemini calls to Vertex AI and spend $2000 GCP Credits)
GCP_PROJECT_ID=""
GCP_LOCATION="us-central1"

# --- DIFY AI ORCHESTRATION CONFIG ---
DIFY_API_URL="http://localhost:5001/v1"
DIFY_DATASET_API_KEY="YOUR_DIFY_DATASET_API_KEY"
DIFY_CHAT_APP_API_KEY="YOUR_DIFY_CHAT_APP_API_KEY"
DIFY_SUMMARY_APP_API_KEY="YOUR_DIFY_SUMMARY_APP_API_KEY"
DIFY_QUIZ_APP_API_KEY="YOUR_DIFY_QUIZ_APP_API_KEY"
DIFY_FLASHCARD_APP_API_KEY="YOUR_DIFY_FLASHCARD_APP_API_KEY"



# --- DOCKER INTERNAL SETTINGS (Keep these for production) ---
DATABASE_URL="postgresql://user:password@db:5432/learnproof_db"
# Social Hub (dating) DB — can be same DB as DATABASE_URL; social tables are prefixed with 'social_'
SOCIAL_DATABASE_URL="postgresql://user:password@db:5432/learnproof_db"
REDIS_URL="redis://cache:6379"

# --- SERVER SETTINGS ---
PORT=8000
NODE_ENV=production
